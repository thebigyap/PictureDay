<Window x:Class="PictureDay.MainWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:local="clr-namespace:PictureDay"
	xmlns:views="clr-namespace:PictureDay.Views"
	mc:Ignorable="d"
	Title="PictureDay" Height="680" Width="1020"
	WindowStartupLocation="CenterScreen"
	WindowStyle="None"
	AllowsTransparency="True"
	Background="Transparent"
	ResizeMode="NoResize"
	TextOptions.TextFormattingMode="Ideal"
	FontFamily="{DynamicResource AppFont}"
	Closing="Window_Closing">

	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVis"/>
	</Window.Resources>

	<!-- Outer transparent margin makes room for the soft drop shadow -->
	<Border Margin="14" CornerRadius="14" Background="{DynamicResource WindowBackgroundBrush}"
			BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1">
		<Border.Effect>
			<DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="32" ShadowDepth="6" Opacity="0.30"/>
		</Border.Effect>

		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="220"/>
				<ColumnDefinition Width="*"/>
			</Grid.ColumnDefinitions>

			<!-- ===================== Sidebar ===================== -->
			<Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}"
					CornerRadius="14,0,0,14" MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
				<DockPanel Margin="16,18,16,18">

					<!-- Brand -->
					<StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,0,0,22">
						<Image Source="pack://application:,,,/Assets/PictureDay_NoText.png"
							   Width="30" Height="30" RenderOptions.BitmapScalingMode="HighQuality"/>
						<StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
							<TextBlock Text="PictureDay" FontSize="16" FontWeight="SemiBold"
									   Foreground="{DynamicResource TextBrush}"/>
							<TextBlock x:Name="VersionText" Text="v2.5.4" FontSize="11"
									   Foreground="{DynamicResource TextSecondaryBrush}"/>
						</StackPanel>
					</StackPanel>

					<!-- Bottom action stack -->
					<StackPanel DockPanel.Dock="Bottom">
						<Button x:Name="TakeScreenshotButton" Style="{StaticResource AccentButton}"
								HorizontalAlignment="Stretch" Margin="0,0,0,8"
								Click="TakeScreenshotButton_Click">
							<StackPanel Orientation="Horizontal">
								<Path Width="17" Height="17" Stretch="Uniform" Margin="0,0,8,0"
									  Stroke="{DynamicResource AccentForegroundBrush}" StrokeThickness="1.6"
									  Fill="Transparent"
									  Data="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z M12 17a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/>
								<TextBlock Text="Take Screenshot" VerticalAlignment="Center"/>
							</StackPanel>
						</Button>
						<Button x:Name="OpenPhotosButton" Style="{StaticResource GhostButton}"
								HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
								Click="OpenPhotosButton_Click" Content="Open Photos Folder"/>
						<Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="6,10"/>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="*"/>
							</Grid.ColumnDefinitions>
							<Button x:Name="PatreonButton" Grid.Column="0" Style="{StaticResource PatreonGhostButton}"
									HorizontalContentAlignment="Left" Padding="8,7" Margin="0,0,4,0"
									Click="PatreonButton_Click">
								<StackPanel Orientation="Horizontal">
									<Path Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"
										  Fill="#FF424D"
										  Data="M0 .48v23.04h4.22V.48zm15.385 0c-4.764 0-8.641 3.881-8.641 8.65 0 4.755 3.877 8.65 8.641 8.65 4.75 0 8.615-3.895 8.615-8.65 0-4.769-3.865-8.65-8.615-8.65z"/>
									<TextBlock Text="Patreon" VerticalAlignment="Center"
											   Foreground="{DynamicResource TextSecondaryBrush}"/>
								</StackPanel>
							</Button>
							<Button x:Name="DonateButton" Grid.Column="1" Style="{StaticResource GhostButton}"
									HorizontalContentAlignment="Left" Padding="8,7" Margin="4,0,0,0"
									Click="DonateButton_Click">
								<StackPanel Orientation="Horizontal">
									<Image Source="pack://application:,,,/Assets/Coffee.png" Width="16" Height="16" Margin="0,0,6,0"/>
									<TextBlock Text="Coffee" VerticalAlignment="Center"
											   Foreground="{DynamicResource TextSecondaryBrush}"/>
								</StackPanel>
							</Button>
						</Grid>
					</StackPanel>

					<!-- Navigation -->
					<StackPanel DockPanel.Dock="Top">
						<RadioButton x:Name="GalleryNav" Style="{StaticResource NavItem}" GroupName="Nav" IsChecked="True"
								 PreviewMouseLeftButtonDown="GalleryNav_PreviewMouseLeftButtonDown">
							<StackPanel Orientation="Horizontal">
								<Path Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0"
									  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
									  StrokeThickness="2" Fill="Transparent"
									  Data="M3 3h7v7H3z M14 3h7v7h-7z M14 14h7v7h-7z M3 14h7v7H3z"/>
								<TextBlock Text="Gallery" VerticalAlignment="Center"/>
							</StackPanel>
						</RadioButton>
						<RadioButton x:Name="SettingsNav" Style="{StaticResource NavItem}" GroupName="Nav">
							<StackPanel Orientation="Horizontal">
								<Path Width="18" Height="18" Stretch="Uniform" Margin="0,0,12,0"
									  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
									  StrokeThickness="2" Fill="Transparent" StrokeLineJoin="Round"
									  Data="M4 21v-7 M4 10V3 M12 21v-9 M12 8V3 M20 21v-5 M20 12V3 M1 14h6 M9 8h6 M17 16h6"/>
								<TextBlock Text="Settings" VerticalAlignment="Center"/>
							</StackPanel>
						</RadioButton>
					</StackPanel>
				</DockPanel>
			</Border>

			<!-- ===================== Content ===================== -->
			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
					<RowDefinition Height="46"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<!-- Title bar (drag region + window controls) -->
				<Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
						<Button Style="{StaticResource CaptionButton}" Click="MinimizeButton_Click"
								Tag="M0,0 H10" ToolTip="Minimize"/>
						<Button Style="{StaticResource CloseCaptionButton}" Click="CloseButton_Click"
								Tag="M0,0 L10,10 M10,0 L0,10" ToolTip="Close"/>
					</StackPanel>
				</Grid>

				<!-- View host -->
				<Border Grid.Row="1" CornerRadius="0,0,14,0">
					<Grid>
						<views:PhotoGalleryView x:Name="PhotoGalleryViewControl"
												Visibility="{Binding IsChecked, ElementName=GalleryNav, Converter={StaticResource BoolToVis}}"/>
						<views:SettingsView x:Name="SettingsViewControl"
											Visibility="{Binding IsChecked, ElementName=SettingsNav, Converter={StaticResource BoolToVis}}"/>
					</Grid>
				</Border>
			</Grid>

			<!-- Toast notification -->
			<Border x:Name="ToastHost" Grid.ColumnSpan="2" Panel.ZIndex="100"
					Visibility="Collapsed" Opacity="0"
					VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,30"
					Background="{DynamicResource CardBackgroundBrush}"
					BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
					CornerRadius="12" Padding="18,12">
				<Border.RenderTransform>
					<TranslateTransform x:Name="ToastTransform"/>
				</Border.RenderTransform>
				<Border.Effect>
					<DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="24" ShadowDepth="5" Opacity="0.30"/>
				</Border.Effect>
				<StackPanel Orientation="Horizontal">
					<Border Width="22" Height="22" CornerRadius="11" Background="#34C759" Margin="0,0,11,0">
						<Path Data="M5 11 L9 15 L17 6" Stroke="White" StrokeThickness="2"
							  StrokeEndLineCap="Round" StrokeStartLineCap="Round" StrokeLineJoin="Round"
							  Stretch="Uniform" Margin="5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>
					<TextBlock x:Name="ToastText" Text="Saved" VerticalAlignment="Center"
							   FontSize="13.5" FontWeight="Medium" Foreground="{DynamicResource TextBrush}"/>
				</StackPanel>
			</Border>
		</Grid>
	</Border>
</Window>
