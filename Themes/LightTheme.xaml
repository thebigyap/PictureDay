<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- ============== Light palette (Apple-inspired) ============== -->

	<!-- Backgrounds -->
	<SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F7"/>
	<SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F5F7"/>
	<SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
	<SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#ECECEF"/>
	<SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF"/>
	<SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF"/>

	<!-- Text -->
	<SolidColorBrush x:Key="ForegroundBrush" Color="#1D1D1F"/>
	<SolidColorBrush x:Key="TextBrush" Color="#1D1D1F"/>
	<SolidColorBrush x:Key="TextSecondaryBrush" Color="#6E6E73"/>

	<!-- Lines / borders -->
	<SolidColorBrush x:Key="BorderBrush" Color="#D2D2D7"/>
	<SolidColorBrush x:Key="ControlBorderBrush" Color="#D2D2D7"/>
	<SolidColorBrush x:Key="ControlBorderStrongBrush" Color="#B0B0B8"/>
	<SolidColorBrush x:Key="SeparatorBrush" Color="#E5E5EA"/>

	<!-- States -->
	<SolidColorBrush x:Key="ControlHoverBrush" Color="#11000000"/>
	<SolidColorBrush x:Key="ControlPressedBrush" Color="#1F000000"/>
	<SolidColorBrush x:Key="SwitchOffBrush" Color="#E3E3E8"/>

	<!-- Accent -->
	<SolidColorBrush x:Key="AccentBrush" Color="#007AFF"/>
	<SolidColorBrush x:Key="AccentHoverBrush" Color="#1A8CFF"/>
	<SolidColorBrush x:Key="AccentPressedBrush" Color="#0062CC"/>
	<SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF"/>

	<!-- Scrollbar -->
	<SolidColorBrush x:Key="ScrollThumbBrush" Color="#C2C2CC"/>
	<SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#A0A0AC"/>

	<Color x:Key="ShadowColor">#9AA0AB</Color>

	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary Source="Controls.xaml"/>
	</ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
