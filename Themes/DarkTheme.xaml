<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- ============== Dark palette (Apple-inspired) ============== -->

	<!-- Backgrounds -->
	<SolidColorBrush x:Key="BackgroundBrush" Color="#1C1C1E"/>
	<SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1C1C1E"/>
	<SolidColorBrush x:Key="CardBackgroundBrush" Color="#2C2C2E"/>
	<SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#242426"/>
	<SolidColorBrush x:Key="ControlBackgroundBrush" Color="#3A3A3C"/>
	<SolidColorBrush x:Key="InputBackgroundBrush" Color="#1C1C1E"/>

	<!-- Text -->
	<SolidColorBrush x:Key="ForegroundBrush" Color="#F5F5F7"/>
	<SolidColorBrush x:Key="TextBrush" Color="#F5F5F7"/>
	<SolidColorBrush x:Key="TextSecondaryBrush" Color="#98989D"/>

	<!-- Lines / borders -->
	<SolidColorBrush x:Key="BorderBrush" Color="#3A3A3C"/>
	<SolidColorBrush x:Key="ControlBorderBrush" Color="#48484A"/>
	<SolidColorBrush x:Key="ControlBorderStrongBrush" Color="#5A5A5C"/>
	<SolidColorBrush x:Key="SeparatorBrush" Color="#38383A"/>

	<!-- States -->
	<SolidColorBrush x:Key="ControlHoverBrush" Color="#1AFFFFFF"/>
	<SolidColorBrush x:Key="ControlPressedBrush" Color="#2EFFFFFF"/>
	<SolidColorBrush x:Key="SwitchOffBrush" Color="#48484A"/>

	<!-- Accent -->
	<SolidColorBrush x:Key="AccentBrush" Color="#0A84FF"/>
	<SolidColorBrush x:Key="AccentHoverBrush" Color="#3D9BFF"/>
	<SolidColorBrush x:Key="AccentPressedBrush" Color="#0070E0"/>
	<SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF"/>

	<!-- Scrollbar -->
	<SolidColorBrush x:Key="ScrollThumbBrush" Color="#48484A"/>
	<SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#636366"/>

	<Color x:Key="ShadowColor">#000000</Color>

	<ResourceDictionary.MergedDictionaries>
		<ResourceDictionary Source="Controls.xaml"/>
	</ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
