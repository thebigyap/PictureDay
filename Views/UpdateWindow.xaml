<Window x:Class="PictureDay.Views.UpdateWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		Title="PictureDay Update" Height="320" Width="520"
		WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
		WindowStyle="None" AllowsTransparency="True" Background="Transparent"
		FontFamily="{DynamicResource AppFont}">
	<Border Margin="12" CornerRadius="14" Background="{DynamicResource WindowBackgroundBrush}"
			BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1">
		<Border.Effect>
			<DropShadowEffect Color="{DynamicResource ShadowColor}" BlurRadius="28" ShadowDepth="5" Opacity="0.28"/>
		</Border.Effect>
		<Grid Margin="28,24,28,24">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<TextBlock Grid.Row="0" x:Name="TitleTextBlock"
					   Text="Checking for updates..."
					   FontSize="20" FontWeight="SemiBold"
					   Margin="0,0,0,16"
					   Foreground="{DynamicResource TextBrush}"/>

			<StackPanel Grid.Row="1" x:Name="ContentPanel">
				<TextBlock x:Name="MessageTextBlock"
						   Text="Checking for updates..."
						   TextWrapping="Wrap"
						   Margin="0,0,0,20"
						   Foreground="{DynamicResource TextSecondaryBrush}"/>

				<ProgressBar x:Name="DownloadProgressBar"
							 Minimum="0" Maximum="100" Value="0"
							 Visibility="Collapsed" Margin="0,0,0,10"/>

				<TextBlock x:Name="ProgressTextBlock"
						   Text=""
						   HorizontalAlignment="Center"
						   Visibility="Collapsed"
						   Foreground="{DynamicResource TextSecondaryBrush}"/>
			</StackPanel>

			<StackPanel Grid.Row="2" Orientation="Horizontal"
						HorizontalAlignment="Right" Margin="0,8,0,0">
				<Button x:Name="YesButton" Content="Yes" Style="{StaticResource AccentButton}"
						Margin="8,0,0,0" Click="YesButton_Click" Visibility="Collapsed"/>
				<Button x:Name="NoButton" Content="No"
						Margin="8,0,0,0" Click="NoButton_Click" Visibility="Collapsed"/>
				<Button x:Name="CloseButton" Content="Close"
						Margin="8,0,0,0" Click="CloseButton_Click"/>
				<Button x:Name="OkButton" Content="OK" Style="{StaticResource AccentButton}"
						Margin="8,0,0,0" Click="OkButton_Click" Visibility="Collapsed"/>
			</StackPanel>

			<Button Grid.Row="3" x:Name="DownloadButton"
					Content="Download Update" Style="{StaticResource AccentButton}"
					HorizontalAlignment="Stretch" Margin="0,12,0,0"
					Click="DownloadButton_Click" Visibility="Collapsed"/>
		</Grid>
	</Border>
</Window>
