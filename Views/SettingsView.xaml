<UserControl x:Class="PictureDay.Views.SettingsView"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 mc:Ignorable="d"
			 d:DesignHeight="450" d:DesignWidth="800">
	<UserControl.Resources>
		<Style x:Key="SettingCard" TargetType="Border">
			<Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
			<Setter Property="CornerRadius" Value="14"/>
			<Setter Property="BorderBrush" Value="{DynamicResource SeparatorBrush}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="20,18"/>
			<Setter Property="Margin" Value="0,0,0,14"/>
		</Style>
		<Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource HeadlineText}">
			<Setter Property="Margin" Value="0,0,0,8"/>
		</Style>
	</UserControl.Resources>

	<Grid Background="Transparent">
		<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="28,8,28,8">
			<StackPanel>

				<!-- Header -->
				<Grid Margin="0,0,8,18">
					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="Settings" Style="{StaticResource LargeTitleText}"/>
						<TextBlock Text="Tune how PictureDay captures and stores your day"
								   Style="{StaticResource CaptionText}" Margin="0,2,0,0"/>
					</StackPanel>
					<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
						<Button Content="Cancel" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="CancelButton_Click"/>
						<Button Content="Save Changes" Style="{StaticResource AccentButton}" Click="SaveButton_Click"/>
					</StackPanel>
				</Grid>

				<!-- Appearance -->
				<Border Style="{StaticResource SettingCard}">
					<StackPanel>
						<TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,14"/>
						<TextBlock Text="Theme" Style="{StaticResource FieldLabel}"/>
						<ComboBox x:Name="ThemeComboBox" HorizontalAlignment="Left" MinWidth="240"
								  SelectionChanged="ThemeComboBox_SelectionChanged">
							<ComboBoxItem Content="Light" Tag="Light"/>
							<ComboBoxItem Content="Dark" Tag="Dark"/>
						</ComboBox>

						<Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,18"/>

						<Grid>
							<StackPanel VerticalAlignment="Center">
								<TextBlock Text="Start with Windows" Style="{StaticResource HeadlineText}"/>
								<TextBlock Text="Launch PictureDay automatically when you sign in"
										   Style="{StaticResource CaptionText}" Margin="0,2,0,0"/>
							</StackPanel>
							<CheckBox x:Name="StartWithWindowsCheckBox" Style="{StaticResource ToggleSwitch}"
									  HorizontalAlignment="Right" VerticalAlignment="Center"/>
						</Grid>
					</StackPanel>
				</Border>

				<!-- Schedule -->
				<Border Style="{StaticResource SettingCard}">
					<StackPanel>
						<TextBlock Text="SCREENSHOT SCHEDULE" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,14"/>
						<TextBlock Text="When to capture" Style="{StaticResource FieldLabel}"/>
						<ComboBox x:Name="ScheduleModeComboBox" HorizontalAlignment="Left" MinWidth="240"
								  SelectionChanged="ScheduleModeComboBox_SelectionChanged">
							<ComboBoxItem Content="Random Time" Tag="Random"/>
							<ComboBoxItem Content="Fixed Time" Tag="FixedTime"/>
							<ComboBoxItem Content="Time Range" Tag="TimeRange"/>
						</ComboBox>

						<Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="9"
								BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1"
								Padding="14,10" Margin="0,14,0,0">
							<StackPanel Orientation="Horizontal">
								<Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
								<TextBlock x:Name="ScheduledTimeTextBlock" Text="Today's scheduled time: Not set"
										   VerticalAlignment="Center" FontWeight="Medium"
										   Foreground="{DynamicResource TextBrush}"/>
							</StackPanel>
						</Border>

						<StackPanel x:Name="FixedTimePanel" Margin="0,16,0,0" Visibility="Collapsed">
							<TextBlock Text="Scheduled time (HH:mm)" Style="{StaticResource FieldLabel}"/>
							<TextBox x:Name="FixedTimeTextBox" Width="140" HorizontalAlignment="Left" Text="14:00"
									 ToolTip="Enter time in 24-hour format (HH:mm), e.g., 14:00 for 2:00 PM"/>
						</StackPanel>

						<StackPanel x:Name="TimeRangePanel" Margin="0,16,0,0" Visibility="Collapsed">
							<StackPanel Orientation="Horizontal">
								<StackPanel Margin="0,0,24,0">
									<TextBlock Text="Start time (HH:mm)" Style="{StaticResource FieldLabel}"/>
									<TextBox x:Name="RangeStartTimeTextBox" Width="140" HorizontalAlignment="Left" Text="09:00"
											 ToolTip="Enter time in 24-hour format (HH:mm), e.g., 09:00 for 9:00 AM"/>
								</StackPanel>
								<StackPanel>
									<TextBlock Text="End time (HH:mm)" Style="{StaticResource FieldLabel}"/>
									<TextBox x:Name="RangeEndTimeTextBox" Width="140" HorizontalAlignment="Left" Text="21:00"
											 ToolTip="Enter time in 24-hour format (HH:mm), e.g., 21:00 for 9:00 PM"/>
								</StackPanel>
							</StackPanel>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- Capture -->
				<Border Style="{StaticResource SettingCard}">
					<StackPanel>
						<TextBlock Text="CAPTURE" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,14"/>
						<TextBlock Text="Monitors" Style="{StaticResource FieldLabel}"/>
						<StackPanel>
							<RadioButton x:Name="PrimaryMonitorRadio" Content="Primary monitor"
										 GroupName="Monitor" Checked="MonitorSelection_Changed" Margin="0,4"/>
							<RadioButton x:Name="AllMonitorsRadio" Content="All monitors (combined)"
										 GroupName="Monitor" Checked="MonitorSelection_Changed" Margin="0,4"/>
							<RadioButton x:Name="SpecificMonitorRadio" Content="Specific monitor"
										 GroupName="Monitor" Checked="MonitorSelection_Changed" Margin="0,4"/>
							<ComboBox x:Name="MonitorComboBox" HorizontalAlignment="Left" MinWidth="240" Margin="30,6,0,0"
									  IsEnabled="False" SelectionChanged="MonitorComboBox_SelectionChanged"/>
						</StackPanel>

						<Border Height="1" Background="{DynamicResource SeparatorBrush}" Margin="0,18"/>

						<Grid>
							<StackPanel VerticalAlignment="Center">
								<TextBlock Text="Desktop only" Style="{StaticResource HeadlineText}"/>
								<TextBlock Text="Minimize all windows before capturing, showing only the wallpaper"
										   Style="{StaticResource CaptionText}" Margin="0,2,0,0" TextWrapping="Wrap" MaxWidth="420" HorizontalAlignment="Left"/>
							</StackPanel>
							<CheckBox x:Name="DesktopOnlyCheckBox" Style="{StaticResource ToggleSwitch}"
									  HorizontalAlignment="Right" VerticalAlignment="Center"
									  Checked="DesktopOnlyCheckBox_Changed" Unchecked="DesktopOnlyCheckBox_Changed"/>
						</Grid>
					</StackPanel>
				</Border>

				<!-- Image quality -->
				<Border Style="{StaticResource SettingCard}">
					<StackPanel>
						<TextBlock Text="IMAGE QUALITY &amp; FORMAT" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,14"/>
						<TextBlock Text="Format" Style="{StaticResource FieldLabel}"/>
						<ComboBox x:Name="FormatComboBox" HorizontalAlignment="Left" MinWidth="240" Margin="0,0,0,18"
								  SelectionChanged="FormatComboBox_SelectionChanged">
							<ComboBoxItem Content="JPEG" Tag="JPEG" IsSelected="True"/>
							<ComboBoxItem Content="PNG" Tag="PNG"/>
						</ComboBox>

						<TextBlock Text="Quality (JPEG only)" Style="{StaticResource FieldLabel}"/>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<Slider x:Name="QualitySlider" Grid.Column="0" Minimum="10" Maximum="100"
									Value="90" TickFrequency="10" IsSnapToTickEnabled="True"
									VerticalAlignment="Center" Margin="0,0,16,0" ValueChanged="QualitySlider_ValueChanged"/>
							<Border Grid.Column="1" Background="{DynamicResource InputBackgroundBrush}" CornerRadius="7"
									BorderBrush="{DynamicResource SeparatorBrush}" BorderThickness="1" Padding="12,6" MinWidth="52">
								<TextBlock x:Name="QualityValueTextBlock" Text="90" TextAlignment="Center"
										   FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
							</Border>
						</Grid>
					</StackPanel>
				</Border>

				<!-- Privacy -->
				<Border Style="{StaticResource SettingCard}">
					<StackPanel>
						<TextBlock Text="PRIVACY FILTER" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,6"/>
						<TextBlock Text="Screenshots are blocked whenever any of these applications are running."
								   Style="{StaticResource CaptionText}" Margin="0,0,0,12" TextWrapping="Wrap"/>

						<ListBox x:Name="BlockedAppsListBox" Height="150" Margin="0,0,0,12"/>

						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<TextBox x:Name="NewAppTextBox" Grid.Column="0" Margin="0,0,8,0"/>
							<Button Grid.Column="1" Content="Add" Style="{StaticResource AccentButton}" Click="AddAppButton_Click"/>
						</Grid>
						<StackPanel Orientation="Horizontal" Margin="0,8,0,0">
							<Button Content="Remove Selected" Margin="0,0,8,0" Click="RemoveAppButton_Click"/>
							<Button Content="Browse Running Processes" Click="BrowseProcessesButton_Click"/>
						</StackPanel>
					</StackPanel>
				</Border>

				<!-- Storage -->
				<Border Style="{StaticResource SettingCard}">
					<StackPanel>
						<TextBlock Text="STORAGE" Style="{StaticResource SectionHeaderText}" Margin="0,0,0,14"/>
						<TextBlock Text="Screenshot folder" Style="{StaticResource FieldLabel}"/>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<TextBox x:Name="DirectoryTextBox" Grid.Column="0" IsReadOnly="True" Margin="0,0,8,0"/>
							<Button Grid.Column="1" Content="Browse..." Click="BrowseDirectoryButton_Click"/>
						</Grid>
					</StackPanel>
				</Border>

			</StackPanel>
		</ScrollViewer>
	</Grid>
</UserControl>
